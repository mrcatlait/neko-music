{
  "consumer": {
    "name": "web"
  },
  "interactions": [
    {
      "description": "a request to get genre statistics",
      "pending": false,
      "providerStates": [
        {
          "name": "a genre statistics exists"
        }
      ],
      "request": {
        "headers": {
          "Authorization": [
            "Bearer test-access-token"
          ]
        },
        "matchingRules": {
          "header": {
            "Authorization": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "method": "GET",
        "path": "/backstage/genres/statistics"
      },
      "response": {
        "body": {
          "content": {
            "data": [
              {
                "id": "00000000-0000-0000-0000-000000000000",
                "name": "Rock",
                "totalAlbums": 10,
                "totalArtists": 10,
                "totalTracks": 10
              }
            ]
          },
          "contentType": "application/json",
          "encoded": false
        },
        "headers": {
          "Content-Type": [
            "application/json"
          ]
        },
        "matchingRules": {
          "body": {
            "$.data[0].id": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "regex",
                  "regex": "[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}"
                }
              ]
            },
            "$.data[0].name": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.data[0].totalAlbums": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "number"
                }
              ]
            },
            "$.data[0].totalArtists": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "number"
                }
              ]
            },
            "$.data[0].totalTracks": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "number"
                }
              ]
            }
          }
        },
        "status": 200
      },
      "type": "Synchronous/HTTP"
    },
    {
      "description": "a request to login",
      "pending": false,
      "providerStates": [
        {
          "name": "a user exists"
        }
      ],
      "request": {
        "body": {
          "content": {
            "email": "test@example.com",
            "password": "password123"
          },
          "contentType": "application/json",
          "encoded": false
        },
        "headers": {
          "Content-Type": [
            "application/json"
          ]
        },
        "method": "POST",
        "path": "/auth/login"
      },
      "response": {
        "body": {
          "content": {
            "accessToken": "test-access-token",
            "displayName": "John Doe",
            "email": "test@example.com",
            "role": "user"
          },
          "contentType": "application/json",
          "encoded": false
        },
        "headers": {
          "Content-Type": [
            "application/json"
          ]
        },
        "matchingRules": {
          "body": {
            "$.accessToken": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.displayName": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.email": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.role": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "status": 200
      },
      "type": "Synchronous/HTTP"
    }
  ],
  "metadata": {
    "pact-js": {
      "version": "16.3.0"
    },
    "pactRust": {
      "ffi": "0.5.3",
      "models": "1.3.9"
    },
    "pactSpecification": {
      "version": "4.0"
    }
  },
  "provider": {
    "name": "neko-music-api"
  }
}