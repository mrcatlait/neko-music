{
  "consumer": {
    "name": "web"
  },
  "interactions": [
    {
      "description": "a request to login",
      "pending": false,
      "providerStates": [
        {
          "name": "a user exists"
        }
      ],
      "request": {
        "body": {
          "content": {
            "email": "test@example.com",
            "password": "password123"
          },
          "contentType": "application/json",
          "encoded": false
        },
        "headers": {
          "Content-Type": [
            "application/json"
          ]
        },
        "method": "POST",
        "path": "/auth/login"
      },
      "response": {
        "body": {
          "content": {
            "accessToken": "test-access-token",
            "displayName": "John Doe",
            "email": "test@example.com",
            "role": "user"
          },
          "contentType": "application/json",
          "encoded": false
        },
        "headers": {
          "Content-Type": [
            "application/json"
          ]
        },
        "matchingRules": {
          "body": {
            "$.accessToken": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "status": 200
      },
      "type": "Synchronous/HTTP"
    }
  ],
  "metadata": {
    "pact-js": {
      "version": "16.3.0"
    },
    "pactRust": {
      "ffi": "0.5.3",
      "models": "1.3.9"
    },
    "pactSpecification": {
      "version": "4.0"
    }
  },
  "provider": {
    "name": "neko-music-api"
  }
}